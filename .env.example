# Backend Environment Variables (EXAMPLE)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=fnb_db
DB_USER=fnb_user
DB_PASS=your_db_password

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

EUREKA_HOST=localhost
EUREKA_PORT=8761

JWT_SECRET=change-this-to-a-very-long-secret-key-at-least-256-bits-long

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PayOS Configuration
PAYOS_CLIENT_ID=mock
PAYOS_API_KEY=mock
PAYOS_CHECKSUM_KEY=mock

# AI Service (Groq API)
GROQ_API_KEY=mock

# Frontend URL
QR_BASE_URL=http://localhost:5173/?qr=
